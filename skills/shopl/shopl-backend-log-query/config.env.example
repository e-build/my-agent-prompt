# Shopl ES 접속 설정 템플릿
# 복사 후 config.env 로 저장: cp config.env.example config.env && chmod 600 config.env
# 평문 비밀번호 주의 — 파일 권한 600 필수.

# ES 엔드포인트 (보안그룹 작업 후 실제 주소 입력)
# 사내망 EC2(9200) 또는 별도 ALB. 끝에 / 붙이지 말 것.
ES_ENDPOINT=https://shopl-elastic-search.internal:9200

# 인덱스 패턴 (data stream 일별 rollover)
ES_INDEX_PATTERN=shopl-backend-log*

# 인증 방식 — 둘 중 하나만 사용
# 1) Basic auth
ES_USER=
ES_PASS=
# 2) API key (Basic auth 미사용 시)
# ES_API_KEY=

# 타임아웃(초)
ES_TIMEOUT=30

# 자체서명 인증서 등 검증 스킵이 필요하면 -k 설정 (운영 권장 X)
# ES_INSECURE=-k
